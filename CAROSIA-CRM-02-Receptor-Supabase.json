    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// PostgREST con return=representation devuelve [] si no actualizó ninguna fila\nconst items = $input.all();\nconst rr = $('Asignar Round-Robin').first().json;\n\n// Si hay al menos un item con id, el deal existía y fue actualizado\nconst dealExistia = items.length > 0 && items[0].json && items[0].json.id;\n\nreturn [{ json: {\n  deal_existia: dealExistia,\n  contact_id: rr.contact_id,\n  contact_name: rr.contact_name,\n  contact_rubro: rr.contact_rubro,\n  user_id: rr.user_id,\n  vendor_name: rr.vendor_name,\n  vendor_member_user_id: rr.vendor_member_user_id,\n  fecha_respuesta: rr.fecha_respuesta,\n  inbox_body: rr.inbox_body,\n  inbox_preview: rr.inbox_preview,\n  inbox_subject: rr.inbox_subject,\n  wa_vendor_text: rr.wa_vendor_text,\n  wa_owner_text: rr.wa_owner_text,\n  vendor_phone: rr.vendor_phone\n} }];"
      },
