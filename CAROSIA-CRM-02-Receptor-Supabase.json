      "id": "c02s-read-vendors",
      "name": "Leer Vendedores Supabase",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2320,
        160
      ],
      "continueOnFail": true,
      "alwaysOutputData": true
