        "mode": "runOnceForAllItems",
        "jsCode": "// n8n HTTP Request v4.2 splits Supabase array into individual items\nconst items = $input.all();\nconst ex = $('Extraer y Filtrar Mensaje').first().json;\n\nif (items.length === 0 || !items[0].json.id) {\n  return [{ json: {\n    found: false,\n    numero: ex.numero,\n    nombre_remitente: ex.nombre_remitente,\n    texto: ex.texto,\n    fecha_respuesta: ex.fecha_respuesta\n  } }];\n}\n\nconst c = items[0].json;\nreturn [{ json: {\n  found: true,\n  contact_id: c.id,\n  name: c.name,\n  phone: c.phone,\n  status: c.status,\n  user_id: c.user_id,\n  owner_name: c.owner_name || '',\n  rubro: c.rubro || '',\n  numero: ex.numero,\n  texto: ex.texto,\n  nombre_remitente: ex.nombre_remitente,\n  fecha_respuesta: ex.fecha_respuesta\n} }];"
