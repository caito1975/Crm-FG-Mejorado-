      },
      "id": "c02s-webhook",
      "name": "Webhook - Mensaje Entrante",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        400,
        304
      ],
      "webhookId": "b5e8f1a2-receptor-wa-supabase-v1"
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.item.json;\nconst body = raw.body || raw;\n\n// Evolution API webhookBase64:true sends body.data as base64-encoded JSON string\nlet msgData;\nlet rawData = body.data;\n\nif (typeof rawData === 'string') {\n  try {\n    rawData = JSON.parse(Buffer.from(rawData, 'base64').toString('utf8'));\n  } catch(e) {\n    // not valid base64-JSON, leave as string — will fall through below\n  }\n}\n\nif (rawData && typeof rawData === 'object' && rawData.key) {\n  msgData = rawData;\n} else if (rawData && rawData.messages && rawData.messages.length > 0) {\n  msgData = rawData.messages[0];\n} else if (Array.isArray(rawData) && rawData.length > 0) {\n  msgData = rawData[0];\n} else {\n  msgData = body;\n}\n\nconst key = msgData.key || {};\nconst remoteJid = key.remoteJid || '';\nconst fromMe = key.fromMe === true;\nconst isGroup = remoteJid.indexOf('@g.us') !== -1;\n\n// Drop own messages, groups, and empty senders\nif (fromMe || isGroup || !remoteJid) { return []; }\n\nconst message = msgData.message || {};\nconst texto = message.conversation\n  || (message.extendedTextMessage && message.extendedTextMessage.text)\n  || (message.imageMessage && message.imageMessage.caption)\n  || (message.videoMessage && message.videoMessage.caption)\n  || (message.audioMessage ? '[audio]' : null)\n  || (message.documentMessage ? '[documento: ' + (message.documentMessage.fileName || 'archivo') + ']' : null)\n  || (message.stickerMessage ? '[sticker]' : null)\n  || (message.listResponseMessage && message.listResponseMessage.title)\n  || '[media]';\n\nconst pushName = msgData.pushName || '';\nconst numero = remoteJid.replace('@s.whatsapp.net', '').replace(/^[+]/, '');\n\n// Safety: drop if phone empty\nif (!numero) { return []; }\n\nconst fecha_respuesta = new Date().toISOString();\n\nreturn [{ json: { numero, texto, nombre_remitente: pushName, fecha_respuesta } }];"
      },
