        "options": {}
      },
      "id": "c02s-webhook",
      "name": "Webhook - Mensaje Entrante",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [400, 304],
      "webhookId": "b5e8f1a2-receptor-wa-supabase-v1"
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.item.json;\n\nconst payload = (raw && raw.body && typeof raw.body === 'object') ? raw.body : raw;\n\nconst debugInfo = {\n  has_event: !!payload.event,\n  event_value: payload.event || 'NINGUNO',\n  has_data: !!payload.data,\n  data_type: typeof payload.data,\n  payload_keys: Object.keys(payload || {}).slice(0, 10).join(',')\n};\n\nconst event = payload.event || payload.type || '';\n\nif (event && event !== 'messages.upsert') {\n  return [{ json: { skip: true, skip_reason: 'wrong_event:' + event, ...debugInfo } }];\n}\n\nlet dataSource = payload.data || payload;\n\nif (typeof dataSource === 'string') {\n  try {\n    dataSource = JSON.parse(Buffer.from(dataSource, 'base64').toString('utf8'));\n  } catch(e1) {\n    try { dataSource = JSON.parse(dataSource); }\n    catch(e2) {\n      return [{ json: { skip: true, skip_reason: 'data_no_parseable', ...debugInfo } }];\n    }\n  }\n}\n\nlet msgData = null;\nif (dataSource && dataSource.key) {\n  msgData = dataSource;\n} else if (dataSource && Array.isArray(dataSource.messages) && dataSource.messages.length > 0) {\n  msgData = dataSource.messages[0];\n} else if (Array.isArray(dataSource) && dataSource.length > 0) {\n  msgData = dataSource[0];\n} else if (dataSource && typeof dataSource === 'object') {\n  msgData = dataSource;\n}\n\nif (!msgData) {\n  return [{ json: { skip: true, skip_reason: 'no_msg_data', ...debugInfo } }];\n}\n\nconst key = msgData.key || {};\nconst remoteJid = key.remoteJid || msgData.remoteJid || '';\nconst fromMe = key.fromMe === true || msgData.fromMe === true;\nconst isGroup = remoteJid.includes('@g.us');\n\nif (fromMe)     return [{ json: { skip: true, skip_reason: 'from_me', remoteJid, ...debugInfo } }];\nif (isGroup)    return [{ json: { skip: true, skip_reason: 'is_group', remoteJid, ...debugInfo } }];\nif (!remoteJid) return [{ json: { skip: true, skip_reason: 'no_remote_jid', ...debugInfo } }];\n\nconst message = msgData.message || {};\nconst texto = message.conversation\n  || (message.extendedTextMessage && message.extendedTextMessage.text)\n  || (message.imageMessage && message.imageMessage.caption)\n  || (message.videoMessage && message.videoMessage.caption)\n  || (message.audioMessage ? '[audio]' : null)\n  || (message.documentMessage ? '[documento: ' + (message.documentMessage.fileName || 'archivo') + ']' : null)\n  || (message.stickerMessage ? '[sticker]' : null)\n  || (message.listResponseMessage && message.listResponseMessage.title)\n  || '[media]';\n\nconst pushName = msgData.pushName || '';\nconst numero = remoteJid.replace('@s.whatsapp.net', '').replace(/^[+]/, '');\n\nif (!numero) return [{ json: { skip: true, skip_reason: 'no_numero', remoteJid, ...debugInfo } }];\n\nreturn [{ json: {\n  skip: false,\n  numero,\n  texto,\n  nombre_remitente: pushName,\n  fecha_respuesta: new Date().toISOString(),\n  _debug_event: event || 'sin_evento',\n  ...debugInfo\n} }];"
      },
