      "id": "c01-leer", "name": "Leer Contactos Supabase",
      "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nif (items.length === 0) return [];\nif (!Array.isArray(items[0].json)) {\n  return items.map(item => ({ json: item.json }));\n}\nconst arr = items[0].json;\nreturn arr.filter(Boolean).map(contact => ({ json: contact }));"
      },
      "id": "c01-separar", "name": "Separar Contactos",
      "type": "n8n-nodes-base.code", "typeVersion": 2,
      "position": [680, 300]
    },
    {
      "parameters": { "maxItems": 2 },
      "id": "c01-limitar", "name": "Limitar a 2 por corrida",
      "type": "n8n-nodes-base.limit", "typeVersion": 1,
      "position": [900, 300]
    },
    {
      "parameters": { "options": {} },
      "id": "c01-loop", "name": "Loop - Uno por Uno",
      "type": "n8n-nodes-base.splitInBatches", "typeVersion": 3,
      "position": [1120, 300]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst phoneRaw = (item.phone + '').replace(/[^0-9]/g, '');\n\nif (!phoneRaw || phoneRaw.length < 7) return [];\n\nconst waNumber = phoneRaw.length === 10 ? '549' + phoneRaw : phoneRaw;\n\nconst nombre = item.name || 'ahi';\nconst crmNumber = '5491144123687';\n\nconst mensaje = 'Hola ' + nombre + ' \\u{1F44B}\\n'\n  + '\\xBFInvert\\xEDs en publicidad en Instagram o Facebook para tu negocio?\\n\\n'\n  + 'Muchos anunciantes todav\\xEDa pagan sus campa\\xF1as con costos e impuestos innecesarios que terminan reduciendo su presupuesto publicitario.\\n\\n'\n  + 'En FG Medios \\u2014Partner oficial de Meta\\u2014 ayudamos a m\\xE1s de 900 empresas y emprendedores a optimizar la forma en que invierten en publicidad digital \\u2705\\n\\n'\n  + 'En una charla de 15 minutos te mostramos:\\n'\n  + '\\u2714\\uFE0F C\\xF3mo reducir sobrecostos en campa\\xF1as\\n'\n  + '\\u2714\\uFE0F C\\xF3mo mejorar el rendimiento de tu inversi\\xF3n\\n'\n  + '\\u2714\\uFE0F Qu\\xE9 alternativas usan hoy las empresas para escalar mejor en Meta Ads\\n\\n'\n  + 'Toc\\xE1 para responder:\\n\\n'\n  + '\\u2705 *S\\xED, quiero saber m\\xE1s*\\n'\n  + 'https://wa.me/' + crmNumber + '?text=SI\\n\\n'\n  + '\\u274C *No, gracias*\\n'\n  + 'https://wa.me/' + crmNumber + '?text=NO';\n\nreturn [{\n  json: { ...item, _wa_number: waNumber, mensaje: mensaje }\n}];"
      },
      "id": "c01-prep", "name": "Preparar Body WA",
      "type": "n8n-nodes-base.code", "typeVersion": 2,
      "position": [1340, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://fgmedios-evolution-api.aibo5u.easypanel.host/message/sendMedia/carosia-crm",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": { "parameters": [
          { "name": "Content-Type", "value": "application/json" },
          { "name": "apikey",       "value": "429683C4C977415CAAFCCE10F7D57E11" }
        ]},
        "sendBody": true, "specifyBody": "json",
        "jsonBody": "={{ ({ number: $json._wa_number, mediatype: 'image', mimetype: 'image/png', caption: $json.mensaje, media: 'https://meta.fgmedios.com/img/og-image-square3.png' }) }}",
        "options": {
          "response": { "response": { "outputPropertyName": "_evo_resp" } }
        }
      },
      "id": "c01-enviar", "name": "Enviar WhatsApp",
      "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2,
      "position": [1560, 300],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const waResp = $('Enviar WhatsApp').first().json;\nconst prep   = $('Preparar Body WA').first().json;\n\nconst respStr = JSON.stringify(waResp);\nconst failed  = waResp.error !== undefined\n             || respStr.includes('\"exists\":false')\n             || respStr.includes('Bad Request')\n             || respStr.includes('\"status\":404')\n             || respStr.includes('\"status\":500');\n\nconst now_str = new Date().toISOString();\n\nreturn [{ json: {\n  phone:       prep.phone,\n  rubro:       prep.rubro,\n  mensaje:     prep.mensaje,\n  name:        prep.name,\n  contact_id:  prep.id,\n  user_id:     prep.user_id,\n  now_str:     now_str,\n  etapa_final: failed ? 'no_enviado' : 'enviado'\n} }];"
      },
      "id": "c01-evaluar", "name": "Evaluar Resultado WA",
      "type": "n8n-nodes-base.code", "typeVersion": 2,
      "position": [1780, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://resxhwxubboicfpoftjp.supabase.co/rest/v1/activities",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": { "parameters": [
          { "name": "apikey",        "value": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJlc3hod3h1YmJvaWNmcG9mdGpwIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NzcwMDE0MSwiZXhwIjoyMDkzMjc2MTQxfQ.TqcIuu0AJLfZ61s7BYvYCrmophh1t6kLtZQDtdR-L7M" },
          { "name": "Authorization", "value": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJlc3hod3h1YmJvaWNmcG9mdGpwIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NzcwMDE0MSwiZXhwIjoyMDkzMjc2MTQxfQ.TqcIuu0AJLfZ61s7BYvYCrmophh1t6kLtZQDtdR-L7M" },
          { "name": "Content-Type",  "value": "application/json" },
          { "name": "Prefer",        "value": "return=minimal" }
        ]},
        "sendBody": true, "specifyBody": "json",
        "jsonBody": "={{ ({ user_id: $json.user_id, kind: 'call_out', who: 'CarosIA CRM', body: 'WhatsApp ' + ($json.etapa_final === 'enviado' ? 'enviado' : 'fallido') + ': ' + String($json.name || ''), contact_id: $json.contact_id }) }}",
        "options": {}
      },
      "id": "c01-actividad", "name": "Registrar Actividad Supabase",
