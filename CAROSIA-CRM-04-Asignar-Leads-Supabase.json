      "id": "c04s-vendedores",
      "name": "Leer Vendedores",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1560, 300],
      "continueOnFail": true,
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst lead  = $('Preparar Lead').first().json;\n\nconst vendors = items\n  .map(i => i.json)\n  .filter(v => v.id && v.phone);\n\nif (vendors.length === 0) {\n  return [{ json: { _skip: true, contact_id: lead.id, user_id: lead.user_id, contact_name: lead.name } }];\n}\n\nconst minDeals  = Math.min(...vendors.map(v => Number(v.deals_count) || 0));\nconst candidates = vendors.filter(v => (Number(v.deals_count) || 0) === minDeals);\nconst vendor    = candidates[Math.floor(Math.random() * candidates.length)];\n\nconst vendorPhone = String(vendor.phone || '').replace(/\\D/g, '');\nconst now = new Date().toISOString();\n\nconst waText =\n  '\\uD83C\\uDFAF *Nuevo lead para contactar*\\n\\n'\n  + '\\uD83D\\uDC64 *' + (lead.name    || '-') + '*\\n'\n  + '\\uD83C\\uDFE2 '  + (lead.company || '-') + '\\n'\n  + '\\uD83D\\uDCF1 Tel: '   + (lead.phone   || '-') + '\\n'\n  + '\\uD83D\\uDCE7 Email: ' + (lead.email   || '-') + '\\n'\n  + (lead.rubro   ? '\\uD83C\\uDFF7 Rubro: '  + lead.rubro   + '\\n' : '')\n  + (lead.city    ? '\\uD83D\\uDCCD '         + lead.city    + '\\n' : '')\n  + (lead.website ? '\\uD83C\\uDF10 '         + lead.website + '\\n' : '')\n  + '\\nRecord\\u00E1 actualizar el estado en el CRM cuando lo contactes.';\n\nconst inboxBody =\n  'Lead sin env\\u00EDo WA \\u2014 asignado para seguimiento manual\\n\\n'\n  + 'Nombre: '      + (lead.name    || '-') + '\\n'\n  + 'Tel\\u00E9fono: ' + (lead.phone || '-') + '\\n'\n  + 'Empresa: '     + (lead.company || '-') + '\\n'\n  + 'Rubro: '       + (lead.rubro   || '-') + '\\n'\n  + 'Email: '       + (lead.email   || '-') + '\\n\\n'\n  + 'Vendedor asignado: ' + vendor.name;\n\nreturn [{ json: {\n  _skip:            false,\n  contact_id:       lead.id,\n  contact_name:     lead.name,\n  contact_phone:    lead.phone    || '',\n  contact_rubro:    lead.rubro    || '',\n  contact_company:  lead.company  || '',\n  contact_email:    lead.email    || '',\n  user_id:          lead.user_id,\n  vendor_id:            vendor.id,\n  vendor_name:          vendor.name,\n  vendor_phone:         vendorPhone,\n  vendor_member_user_id: vendor.member_user_id || null,\n  vendor_deals_ant:     Number(vendor.deals_count) || 0,\n  now_str:          now,\n  wa_text:          waText,\n  inbox_body:       inboxBody,\n  inbox_subject:    'Lead sin WA: ' + (lead.name || '-') + (lead.rubro ? ' \\u00B7 ' + lead.rubro : ''),\n  inbox_preview:    (lead.name || '-') + ' \\u2014 ' + (lead.phone || '-')\n} }];"
      },
